# -------------------------------
# Server Environment Variables
# The Abel Experience API - Example Environment Configuration
# Copy this file to .env and fill in real values. NEVER commit an actual secret key.
# -------------------------------

# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/taexp

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Auth / Security
JWT_SECRET=changeme_super_secure_string

# Spotify Integration
SPOTIFY_CLIENT_ID=changeme
SPOTIFY_CLIENT_SECRET=changeme
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/api/spotify/callback

# Plaid Integration (MVP)
PLAID_ENABLED=true
PLAID_CLIENT_ID=changeme
PLAID_SECRET=changeme
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Comma-separated allowlist of emails or user IDs. Use * to allow all authenticated users in dev.
PLAID_INVITED_USERS=*
# Optional: required for some OAuth institutions during Link.
PLAID_REDIRECT_URI=http://localhost:5173

# Finance (reserved for future specialized keys)
# FINANCE_API_KEY=

# Sports / Football Tracking
API_FOOTBALL_KEY=changeme
FOOTBALL_SEASON=2025

# (Optional) Adjust cache TTL overrides (in ms) if you add dynamic config later
# STANDINGS_TTL=300000
# FIXTURES_TTL=120000
# PERFORMERS_TTL=300000
# ROSTER_TTL=43200000
# LIVE_TTL=15000

# Frontend URL (used for OAuth redirects etc.)
FRONTEND_URL=http://localhost:5173

# Misc / External future integrations placeholders
# OTHER_SERVICE_KEY=